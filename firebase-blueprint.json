{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile with role",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A massage service booking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceName": { "type": "string" },
        "price": { "type": "number" },
        "customerName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "discount": { "type": "number" },
        "finalPrice": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["pending", "accepted", "assigned", "on_the_way", "arrived", "completed", "declined"]
        },
        "workerId": { "type": "string" },
        "workerEmail": { "type": "string" },
        "workerEarning": { "type": "number" },
        "adminEarning": { "type": "number" },
        "workerPaymentStatus": { "type": "string" },
        "workerLatitude": { "type": "number" },
        "workerLongitude": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "userId",
        "serviceName",
        "price",
        "customerName",
        "mobileNumber",
        "latitude",
        "longitude",
        "finalPrice",
        "status",
        "createdAt"
      ]
    },
    "Report": {
      "title": "Report",
      "description": "A user report or feedback",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "subject",
        "message",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "User massage orders"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "User submitted reports"
    }
  }
}
