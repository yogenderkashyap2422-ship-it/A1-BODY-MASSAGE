rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          ("email" in request.auth.token && request.auth.token.email == "ushakashyap2422@gmail.com")
        );
    }

    function isWorker() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'worker';
    }

    function isValidUser() {
      return hasOnlyAllowedFields(['email', 'role', 'createdAt', 'displayName', 'phone']) &&
             request.resource.data.email is string &&
             request.resource.data.role in ['admin', 'user', 'worker'] &&
             request.resource.data.createdAt is string &&
             (!('displayName' in request.resource.data) || request.resource.data.displayName is string) &&
             (!('phone' in request.resource.data) || request.resource.data.phone is string);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || (isAuthenticated() && resource.data.role == 'admin');
      allow create: if isOwner(userId) && isValidUser();
      allow update: if (isAdmin() && isValidUser()) || (isOwner(userId) && isValidUser() && request.resource.data.role == resource.data.role);
    }

    function isValidOrder() {
      return hasOnlyAllowedFields(['userId', 'serviceName', 'price', 'customerName', 'mobileNumber', 'latitude', 'longitude', 'discount', 'couponCode', 'finalPrice', 'status', 'workerId', 'workerEmail', 'workerEarning', 'adminEarning', 'workerPaymentStatus', 'workerLatitude', 'workerLongitude', 'createdAt']) &&
             validStringLength('serviceName', 1, 100) &&
             validStringLength('customerName', 1, 100) &&
             validStringLength('mobileNumber', 10, 15) &&
             request.resource.data.price is number && request.resource.data.price > 0 &&
             request.resource.data.latitude is number &&
             request.resource.data.longitude is number &&
             request.resource.data.finalPrice is number && request.resource.data.finalPrice >= 0 &&
             ( !('discount' in request.resource.data) || request.resource.data.discount is number ) &&
             ( !('couponCode' in request.resource.data) || request.resource.data.couponCode is string ) &&
             request.resource.data.status in ['pending', 'assigned', 'accepted', 'on_the_way', 'arrived', 'completed', 'declined'] &&
             ( !('workerId' in request.resource.data) || request.resource.data.workerId is string ) &&
             ( !('workerEmail' in request.resource.data) || request.resource.data.workerEmail is string ) &&
             ( !('workerEarning' in request.resource.data) || request.resource.data.workerEarning is number ) &&
             ( !('adminEarning' in request.resource.data) || request.resource.data.adminEarning is number ) &&
             ( !('workerPaymentStatus' in request.resource.data) || request.resource.data.workerPaymentStatus in ['pending', 'paid'] ) &&
             ( !('workerLatitude' in request.resource.data) || request.resource.data.workerLatitude is number ) &&
             ( !('workerLongitude' in request.resource.data) || request.resource.data.workerLongitude is number ) &&
             request.resource.data.createdAt is string;
    }

    function isValidReport() {
      return hasOnlyAllowedFields(['userId', 'subject', 'message', 'createdAt']) &&
             validStringLength('subject', 1, 200) &&
             validStringLength('message', 1, 2000) &&
             request.resource.data.createdAt is string;
    }

    function isValidCoupon() {
      return hasOnlyAllowedFields(['code', 'discountPercentage', 'isActive', 'createdAt']) &&
             validStringLength('code', 1, 50) &&
             request.resource.data.discountPercentage is number &&
             request.resource.data.discountPercentage > 0 &&
             request.resource.data.discountPercentage <= 100 &&
             request.resource.data.isActive is bool &&
             request.resource.data.createdAt is string;
    }

    match /orders/{orderId} {
      allow read: if isDocOwner() || isAdmin() || (isWorker() && resource.data.workerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidOrder() && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() && isValidOrder() && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt) ||
                       (isAdmin() && isValidOrder() && uidNotModified()) ||
                       (isWorker() && isValidOrder() && uidNotModified() && resource.data.workerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidReport() && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() && isValidReport() && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt) || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCoupon();
      allow update: if isAdmin() && isValidCoupon();
      allow delete: if isAdmin();
    }
  }
}
